{
  "name": "prisma-pglite-bridge",
  "packageManager": "pnpm@10.33.0",
  "version": "0.3.0",
  "description": "In-process PGlite bridge for Prisma — zero-TCP, zero-Docker PostgreSQL",
  "keywords": [
    "prisma",
    "pglite",
    "postgresql",
    "testing",
    "in-memory",
    "database",
    "adapter",
    "vitest",
    "jest",
    "driver-adapter"
  ],
  "repository": "drudolf/prisma-pglite-bridge",
  "author": "drudolf",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "check": "biome check . && markdownlint-cli2 '**/*.md' '#node_modules' '#.claude' && knip",
    "check:exports": "attw --pack --profile node16",
    "changeset": "changeset",
    "bench": "tsx benchmark/run.ts",
    "prepublishOnly": "pnpm build && pnpm check:exports",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@prisma/adapter-pg": "^7.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.11",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electric-sql/pglite": "^0.4.4",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "pg": "^8.20.0",
    "pglite-prisma-adapter": "^0.7.2",
    "prisma": "^7.7.0",
    "prisma-pglite": "^2.0.2",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
